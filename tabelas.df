ADD TABLE "filmes"
  AREA "Schema Area"
  DUMP-NAME "filmes"

ADD FIELD "codFilme" OF "filmes" AS integer 
  FORMAT ">>>>9"
  INITIAL "0"
  LABEL "Código"
  POSITION 2
  MAX-WIDTH 4
  COLUMN-LABEL "Código"
